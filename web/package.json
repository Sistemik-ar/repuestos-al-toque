{
  "name": "repuestos-al-toque-web",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "predev": "node scripts/sync-demo.mjs",
    "dev": "next dev -H 0.0.0.0",
    "prebuild": "node scripts/sync-demo.mjs",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:demo": "SEED_DEMO=1 node prisma/seed.mjs",
    "db:seed-zones": "node prisma/seed-zones.mjs",
    "db:backfill-zones": "node scripts/backfill-zones.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node scripts/with-test-env.mjs npx vitest run --config vitest.integration.config.js",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8",
    "e2e": "playwright test",
    "db:local:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:local:down": "docker compose -f docker-compose.test.yml down",
    "db:local:reset": "docker compose -f docker-compose.test.yml down -v && npm run db:local:up && npm run db:local:setup",
    "db:local:setup": "node scripts/with-test-env.mjs npx prisma db push && node scripts/with-test-env.mjs node prisma/seed.mjs",
    "e2e:local": "node scripts/with-test-env.mjs npx playwright test",
    "dev:local": "node scripts/with-test-env.mjs npx next dev -H 0.0.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@sentry/nextjs": "^10.58.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.10",
    "prisma": "^5.18.0",
    "vitest": "^4.1.8"
  }
}
