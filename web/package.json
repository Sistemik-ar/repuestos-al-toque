{
  "name": "repuestos-al-toque-web",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "predev": "node scripts/sync-demo.mjs",
    "dev": "next dev -H 0.0.0.0",
    "prebuild": "node scripts/sync-demo.mjs",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
