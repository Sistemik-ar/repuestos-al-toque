    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "jose": "^6.2.3",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prisma": "^5.18.0",
    "vitest": "^4.1.8"
  }
}
