# Entorno LOCAL de pruebas (no son secretos reales — credenciales dummy de la DB en Docker).
# Se usa con `npm run db:local:setup` y `npm run e2e:local`. NO afecta producción
# (prod usa las variables de entorno de Vercel, no este archivo).

# Postgres local del docker-compose.test.yml (puerto 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/repuestos?schema=public"

# Secreto de sesión solo para local (en prod va el real en Vercel)
AUTH_SECRET="local-test-secret-no-usar-en-prod"

# Modo prueba de pagos: el atajo de confirmación de los E2E (sin Mercado Pago real)
MP_TEST_AMOUNT="10"
MP_TEST_ACCESS_TOKEN="TEST-local-dummy-token"
